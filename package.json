{
    "name": "screepsai",
    "version": "1.0.6",
    "description": "Screeps AI bot",
    "main": "dist/main.js",
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c -w",
        "localdeploy": "npm version patch --no-git-tag-version && npm run build",
        "deploy": "npm version patch --no-git-tag-version && npm run build && node scripts/deploy.mjs",
        "lint": "eslint src/",
        "format": "prettier --write 'src/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts'",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "engines": {
        "node": ">=20"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/screeps": "^3.3.8",
        "eslint": "^10.2.0",
        "prettier": "^3.8.2",
        "rollup": "^4.60.1",
        "tslib": "^2.8.1",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1"
    }
}
